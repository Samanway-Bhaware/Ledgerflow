# Copy to .env and adjust as needed. docker-compose defaults match these.

# Kafka
KAFKA_BOOTSTRAP=kafka:9092
KAFKA_TOPIC=transactions.raw
KAFKA_GROUP=warehouse-loader

# Postgres (warehouse)
PG_HOST=postgres
PG_PORT=5432
PG_DB=warehouse
PG_USER=pipeline
PG_PASSWORD=pipeline

# Producer behaviour
EVENTS_PER_SECOND=20
N_USERS=500
N_MERCHANTS=120
